{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.harness/skills-src/hooks/git-guard.sh\"" },
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.harness/skills-src/hooks/persona-gate.sh\"" },
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.harness/skills-src/hooks/phase-guard.sh\"" },
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.harness/skills-src/hooks/quality-gate.sh\"" },
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.harness/skills-src/hooks/review-gate.sh\"" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.harness/skills-src/hooks/context-budget-guard.sh\"" },
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.harness/skills-src/hooks/caveman-budget.sh\"" },
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.harness/skills-src/hooks/step-gate.sh\"" },
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.harness/skills-src/hooks/session-guard.sh\"" },
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.harness/skills-src/hooks/notify.sh\"" }
        ]
      }
    ]
  }
}
